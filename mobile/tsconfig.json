{
  "compilerOptions": {
    "skipLibCheck": true,
    "noImplicitAny": false,
    "target": "ESNext",
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "noEmit": true
  },
  "exclude": [
    "node_modules",
    "**/node_modules/*",
    "android",
    "**/android/**",
    "ios",
    "**/ios/**",
    ".expo",
    "**/.expo/**",
    "dist",
    "build"
  ],
  "extends": "./node_modules/expo/tsconfig.base"
}
