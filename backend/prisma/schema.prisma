generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id                        Int       @id @default(autoincrement())
  email                     String    @unique(map: "idx_users_email_unique") @db.VarChar(255)
  password                  String
  role                      String    @default("FAN") @db.VarChar(20)
  isDeleted                 Boolean   @default(false) @map("is_deleted")
  deletedAt                 DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletionReason            String?   @map("deletion_reason")
  status                    String    @default("ACTIVE") @db.VarChar(20)
  artistStatus              String    @default("PENDING") @map("artist_status") @db.VarChar(20)
  is_verified               Boolean   @default(false)
  verified                  Boolean   @default(false)
  trust_score               Int       @default(100)
  strike_count              Int       @default(0)
  name                      String?   @db.VarChar(255)
  profile_image_url         String?
  artistBio                 String?   @map("artist_bio")
  portfolioLinks            String[]  @default([]) @map("portfolio_links")
  onboardedAt               DateTime? @map("onboarded_at") @db.Timestamptz(6)
  created_at                DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                DateTime  @default(now()) @db.Timestamptz(6)
  phone                     String?   @db.VarChar(50)
  genre                     String?   @db.VarChar(50)
  bio                       String?
  banner_image_url          String?
  accent_color              String?   @db.VarChar(20)
  social_links              Json?
  subscription_price        Decimal   @default(0) @db.Decimal
  admin_remarks             String?
  artist_appeal_message     String?
  subscription_features     Json      @default("[]")
  yearly_subscription_price Decimal   @default(0) @db.Decimal
  agreementAccepted         Boolean   @default(false) @map("agreement_accepted")
  agreementAcceptedAt       DateTime? @map("agreement_accepted_at") @db.Timestamptz(6)
  agreementVersion          String?   @map("agreement_version") @db.VarChar(20)
  artistRevenueShare        Int?      @map("artist_revenue_share")
  platformRevenueShare      Int?      @map("platform_revenue_share")
  digitalSignature          String?   @map("digital_signature") @db.Text
  signatureSignedAt         DateTime? @map("signature_signed_at") @db.Timestamptz(6)
  agreementId               String?   @map("agreement_id") @db.VarChar(100)
  termsVersion              String?   @map("terms_version") @db.VarChar(20)
  agreementStatus           String?   @map("agreement_status") @db.VarChar(20)
  agreementStartDate        DateTime? @map("agreement_start_date") @db.Timestamptz(6)
  agreementPdfPath          String?   @map("agreement_pdf_path") @db.VarChar(500)
  signatureIpAddress        String?   @map("signature_ip_address") @db.VarChar(50)
  signatureUserAgent        String?   @map("signature_user_agent") @db.Text

  @@index([artistStatus], map: "idx_users_artist_status")
  @@index([isDeleted], map: "idx_users_is_deleted")
  @@index([role], map: "idx_users_role")
  @@index([agreementId], map: "idx_users_agreement_id")
}

model artist_stats {
  artist_id         Int      @id
  total_plays       Int      @default(0)
  total_subscribers Int      @default(0)
  total_earnings    Decimal  @default(0) @db.Decimal
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)
}

model revenue_share_configs {
  id                Int      @id @default(autoincrement())
  version           String   @unique @db.VarChar(20)
  artistShare       Int      @map("artist_share")
  platformShare     Int      @map("platform_share")
  effectiveFrom     DateTime @map("effective_from") @db.Timestamptz(6)
  isActive          Boolean  @default(true) @map("is_active")
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)

  @@index([version], map: "idx_revenue_share_configs_version")
  @@index([effectiveFrom], map: "idx_revenue_share_configs_effective_from")
}

model terms_versions {
  id                Int      @id @default(autoincrement())
  version           String   @unique @db.VarChar(20)
  content           String   @db.Text
  isActive          Boolean  @default(true) @map("is_active")
  effectiveFrom     DateTime @map("effective_from") @db.Timestamptz(6)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)

  @@index([version], map: "idx_terms_versions_version")
  @@index([effectiveFrom], map: "idx_terms_versions_effective_from")
}

model content_items {
  id                       Int       @id @default(autoincrement())
  title                    String    @db.VarChar(255)
  type                     String    @db.VarChar(20)
  artist_id                Int
  thumbnail_url            String?
  media_url                String?
  audio_url                String?
  video_url                String?
  genre                    String?   @db.VarChar(80)
  lifecycle_state          String    @default("PUBLISHED") @db.VarChar(20)
  is_approved              Boolean   @default(true)
  rejection_reason         String?
  reportCount              Int       @default(0) @map("report_count")
  created_at               DateTime  @default(now()) @db.Timestamptz(6)
  published_at             DateTime? @db.Timestamptz(6)
  subscription_required    Boolean   @default(false)
  storage_provider         String?   @default("local") @map("storage_provider") @db.VarChar(20)
  storage_key              String?   @map("storage_key")
  thumbnail_storage_key    String?   @map("thumbnail_storage_key")
  visibility               String?   @default("PROTECTED") @db.VarChar(30)
  status                   String?   @default("APPROVED") @db.VarChar(20)
  mime_type                String?   @map("mime_type") @db.VarChar(100)
  file_size_bytes          Int?      @map("file_size_bytes")
  original_file_name       String?   @map("original_file_name") @db.VarChar(255)
  uploaded_at              DateTime? @map("uploaded_at") @db.Timestamptz(6)
  video_storage_key        String?   @map("video_storage_key")
  fileKey                  String?   @map("file_key")
  providerAssetId          String?   @map("provider_asset_id")
  audioProviderAssetId     String?   @map("audio_provider_asset_id")
  videoProviderAssetId     String?   @map("video_provider_asset_id")
  thumbnailProviderAssetId String?   @map("thumbnail_provider_asset_id")

  @@index([audioProviderAssetId], map: "idx_content_items_audio_provider_asset_id")
  @@index([storage_provider], map: "idx_content_items_storage_provider")
  @@index([thumbnailProviderAssetId], map: "idx_content_items_thumbnail_provider_asset_id")
  @@index([videoProviderAssetId], map: "idx_content_items_video_provider_asset_id")
}

model reports {
  id        Int      @id @default(autoincrement())
  reason    String?  @db.VarChar(80)
  contentId Int?     @map("content_id")
  userId    Int?     @map("user_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([contentId, userId], map: "idx_reports_unique_content_user")
}

model subscriptions {
  id                Int       @id @default(autoincrement())
  user_id           Int
  artist_id         Int
  status            String    @default("INACTIVE") @db.VarChar(20)
  plan_type         String?   @db.VarChar(50)
  start_date        DateTime  @default(now()) @db.Timestamptz(6)
  next_billing_date DateTime? @db.Timestamptz(6)
  auto_renew        Boolean   @default(true)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime  @default(now()) @db.Timestamptz(6)
  type              String    @default("ARTIST") @db.VarChar(20)
  canceled_at       DateTime? @db.Timestamptz(6)

  @@unique([user_id, artist_id], map: "idx_subscriptions_user_artist")
  @@index([status, type, next_billing_date], map: "idx_subscriptions_composite_health")
  @@index([start_date, status], map: "idx_subscriptions_growth_trend")
}

model content_plays {
  id         Int      @id @default(autoincrement())
  content_id Int
  user_id    Int?
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([content_id], map: "idx_content_plays_content_id")
  @@index([created_at], map: "idx_content_plays_created_at")
}

model content_reactions {
  id         Int      @id @default(autoincrement())
  content_id Int
  user_id    Int
  reaction   String   @db.VarChar(20)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@unique([content_id, user_id], map: "idx_content_reactions_unique")
  @@index([content_id], map: "idx_content_reactions_content_id")
}

model platform_subscription_configs {
  id              Int      @id @default(autoincrement())
  price           Decimal  @db.Decimal
  currency        String   @default("INR") @db.VarChar(10)
  duration        String   @default("monthly") @db.VarChar(20)
  features        Json     @default("[]")
  is_active       Boolean  @default(true)
  discount_price  Decimal? @db.Decimal
  discount_months Int?     @default(1)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
  yearly_price    Decimal? @db.Decimal
}

model processed_webhook_events {
  event_id   String   @id @db.VarChar(100)
  provider   String   @default("razorpay") @db.VarChar(50)
  created_at DateTime @default(now()) @db.Timestamptz(6)
}

model subscription_audit_logs {
  id              Int      @id @default(autoincrement())
  user_id         Int
  subscription_id Int?
  event_type      String   @db.VarChar(50)
  metadata        Json?
  created_at      DateTime @default(now()) @db.Timestamptz(6)
}

model upsell_metrics {
  user_id           Int      @id
  interaction_count Int      @default(0)
  last_attempt_at   DateTime @default(now()) @db.Timestamptz(6)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
}

model user_sessions {
  id             Int      @id @default(autoincrement())
  user_id        Int
  device_id      String   @db.VarChar(255)
  device_name    String?  @db.VarChar(255)
  last_active_at DateTime @default(now()) @db.Timestamptz(6)
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  @@unique([user_id, device_id], map: "idx_user_sessions_device")
  @@index([user_id], map: "idx_user_sessions_user_id")
}

model user_listening_stats {
  user_id       Int
  year          Int
  month         Int
  total_seconds BigInt @default(0)

  @@id([user_id, year, month])
  @@index([user_id, year, month], map: "idx_user_listening_stats_lookup")
}
